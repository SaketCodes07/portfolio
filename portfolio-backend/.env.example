# Copy this file to ".env" and fill in real values. Never commit the real .env file.

# Secret key you invent yourself — send it as the X-Admin-Key header to GET /api/messages
ADMIN_KEY=change-me-to-something-random

# Comma-separated list of frontend origins allowed to call this API.
# Use "*" while testing locally; lock it down before going live.
ALLOWED_ORIGINS=*

# --- Optional: email notifications when someone submits the contact form ---
# Leave these blank to skip email entirely (messages are still saved to the database).
# For Gmail: enable 2-Step Verification, then create an "App Password" — use that
# as SMTP_PASS, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
NOTIFY_EMAIL=youraddress@gmail.com
